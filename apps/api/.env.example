# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Deployment
DEPLOYMENT_MODE=personal
# Options: personal | team-host | team-member

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contextsync
DATABASE_PROVIDER=self-hosted
# Options: self-hosted | supabase
DATABASE_SSL=false
# DATABASE_SSL_CA=/path/to/ca.pem
RUN_MIGRATIONS=true

# Supabase (when DATABASE_PROVIDER=supabase):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_PROVIDER=supabase
# DATABASE_SSL=true

# Auth
# JWT_SECRET has a dev default — override in production!
# JWT_SECRET=your_jwt_secret_min_32_chars_long!!
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Optional: PRD Analysis
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Notifications
# SLACK_WEBHOOK_URL=
# RESEND_API_KEY=
# EMAIL_FROM=noreply@contextsync.dev
