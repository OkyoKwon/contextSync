# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contextsync
DATABASE_SSL=false
# DATABASE_SSL_CA=/path/to/ca.pem
RUN_MIGRATIONS=true

# Supabase cloud example:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_SSL=true

# Remote database (optional — for dual DB / team projects)
# REMOTE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@pooler.supabase.com:6543/postgres
# REMOTE_DATABASE_SSL=false
# REMOTE_DATABASE_SSL_CA=/path/to/remote-ca.pem

# Auth
# JWT_SECRET has a dev default — override in production!
# JWT_SECRET=your_jwt_secret_min_32_chars_long!!
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Optional: PRD Analysis & AI Evaluation
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Slack Notifications
# SLACK_WEBHOOK_URL=
