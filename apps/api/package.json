{
  "name": "@context-sync/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "migrate": "tsx --env-file-if-exists=.env src/database/migrate.ts",
    "seed": "tsx --env-file-if-exists=.env src/database/seed.ts",
    "seed:marketing": "tsx --env-file-if-exists=.env src/database/seed-marketing/index.ts",
    "setup:team": "tsx src/scripts/setup-team.ts",
    "dev:profile": "tsx src/scripts/dev-profile.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@context-sync/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@slack/webhook": "^7.0.0",
    "fastify": "^5.2.0",
    "kysely": "^0.28.14",
    "pg": "^8.13.0",
    "resend": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
