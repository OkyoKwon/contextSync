{
  "name": "@context-sync/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:landing": "tsc && vite build --mode landing",
    "build:static": "tsc && vite build --config vite.config.landing.ts --mode static",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist dist-landing"
  },
  "dependencies": {
    "@context-sync/shared": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-virtual": "^3.13.23",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.0",
    "react-hook-form": "^7.54.0",
    "react-markdown": "^9.0.0",
    "react-router": "^7.1.0",
    "remark-gfm": "^4.0.0",
    "sonner": "^2.0.7",
    "three": "^0.183.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.0.2",
    "msw": "^2.13.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
